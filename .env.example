# BreadMind Configuration
# Copy this file to config/.env and edit as needed:
#   cp .env.example config/.env

# LLM Provider API Keys (at least one required)
# GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=breadmind
DB_USER=breadmind
DB_PASSWORD=breadmind_dev

# Application
BREADMIND_PORT=8080

# Coding — long-running job monitoring
# JobDbWriter bounded-queue maxsize. Drop_newest fires when full.
# Increase if you see coding_db_writer_drops_total{reason="queue_full"} ticks.
BREADMIND_CODING_DB_QUEUE_MAX=2000
