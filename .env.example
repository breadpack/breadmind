# BreadMind Configuration
# Copy this file to config/.env and edit as needed:
#   cp .env.example config/.env

# LLM Provider API Keys (at least one required)
# GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=breadmind
DB_USER=breadmind
DB_PASSWORD=breadmind_dev

# Application
BREADMIND_PORT=8080

# Coding — long-running job monitoring
# JobDbWriter bounded-queue maxsize. Drop_newest fires when full.
# Increase if you see coding_db_writer_drops_total{reason="queue_full"} ticks.
BREADMIND_CODING_DB_QUEUE_MAX=2000

# Episodic Memory Recorder (Phase 1) — see docs/operations/episodic-memory.md
BREADMIND_EPISODIC_NORMALIZE=on
BREADMIND_EPISODIC_NORMALIZE_TIMEOUT_SEC=8
BREADMIND_EPISODIC_QUEUE_MAX=200
BREADMIND_EPISODIC_RECALL_TURN_K=5
BREADMIND_EPISODIC_RECALL_TOOL_K=3
BREADMIND_EPISODIC_RECALL_DECAY_DAYS=7

# Native Messenger M1 (Slack-replacement) — see docs/superpowers/specs/2026-04-26-messenger-foundation-design.md
# PASETO key (32 bytes = 64 hex chars). Generate: python -c "import secrets; print(secrets.token_hex(32))"
BREADMIND_MESSENGER_PASETO_KEY_HEX=
BREADMIND_MESSENGER_OTP_SMTP_URL=smtp://localhost:25
BREADMIND_MESSENGER_OTP_FROM=noreply@breadmind.local
BREADMIND_MESSENGER_OTP_TTL_MIN=10
BREADMIND_MESSENGER_OTP_MAX_ATTEMPTS=5
BREADMIND_MESSENGER_SESSION_ACCESS_TTL_MIN=30
BREADMIND_MESSENGER_SESSION_REFRESH_TTL_DAYS=30
BREADMIND_MESSENGER_INVITE_TTL_DAYS=14
BREADMIND_MESSENGER_VISIBLE_CHANNELS_TTL_SEC=300
BREADMIND_MESSENGER_RATE_LIMIT_TIER1=1
BREADMIND_MESSENGER_RATE_LIMIT_TIER2=50
BREADMIND_MESSENGER_RATE_LIMIT_TIER3=500
BREADMIND_MESSENGER_FILE_BACKEND=fs
BREADMIND_MESSENGER_FILE_FS_ROOT=/var/lib/breadmind/files
BREADMIND_MESSENGER_FANOUT_BACKEND=pg_notify
BREADMIND_MESSENGER_CURSOR_KEY=dev-cursor-key
